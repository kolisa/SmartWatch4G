<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>SmartWatch4G.Infrastructure</RootNamespace>
    <AssemblyName>SmartWatch4G.Infrastructure</AssemblyName>
    <!-- CS8981: lowercase type aliases in auto-generated Protobuf files -->
    <!-- EF1001: intentional use of internal EF Core APIs in SafeMigrationsModelDiffer -->
    <NoWarn>$(NoWarn);CS8981;EF1001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SmartWatch4G.Domain\SmartWatch4G.Domain.csproj" />
    <ProjectReference Include="..\SmartWatch4G.Application\SmartWatch4G.Application.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" />
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" />
    <PackageReference Include="Microsoft.Extensions.Http" />
  </ItemGroup>
</Project>
